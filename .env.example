# API bind
FAHMAI_API_HOST=0.0.0.0
FAHMAI_API_PORT=8888

# Local data and embedding model
FAHMAI_DATABASE=data-parser/output/fahmai.duckdb
FAHMAI_EMBEDDING_MODEL=BAAI/bge-m3
FAHMAI_EMBEDDING_MODEL_PATH=/root/data/model/bge-m3
FAHMAI_EMBEDDING_DEVICE=cpu
FAHMAI_OFFLINE=true
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_HOME=/root/data/hf-cache

# Default backend: Qwen NVFP4 served by vLLM on B200
FAHMAI_LLM_MODE=openai_compatible
FAHMAI_LLM_API_BASE=http://127.0.0.1:8001/v1
FAHMAI_LLM_MODEL=qwen-local
FAHMAI_LLM_TIMEOUT=600

# ThaiLLM/Typhoon backend
FAHMAI_THAILLM_LLM_API_BASE=http://127.0.0.1:8002/v1
FAHMAI_THAILLM_LLM_MODEL=typhoon-local

# Pipeline behavior
FAHMAI_ENABLE_INPUT_GUARD=true
FAHMAI_PIPELINE_MODE=execute
FAHMAI_ENABLE_SQL_GENERATION=true
FAHMAI_ENABLE_ANSWER_SYNTHESIS=true
FAHMAI_ENABLE_SQL_TOOLS=true
FAHMAI_SQL_TOOL_MODE=deterministic
FAHMAI_TOP_K=3
FAHMAI_CANDIDATE_K=30
FAHMAI_SNIPPET_CHARS=360
FAHMAI_LLM_SQL_MAX_TOKENS=2048
FAHMAI_LLM_ANSWER_MAX_TOKENS=3072
